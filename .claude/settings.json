{
  "hooks": {
    "PreToolUse": [
      {
        "tools": ["Bash"],
        "run": "python scripts/integrations/ecc/ecc_hook_bridge.py --tool Bash --delegate scripts/tools/safe_bash.py"
      }
    ]
  },
  "settings": {
    "safetyClassifierEnabled": true,
    "defaultMaxFiles": 20,
    "budgetLimitEnabled": true
  }
}
